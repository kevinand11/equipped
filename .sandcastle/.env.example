# Auth — pick ONE of the two below.
#
# Option A (recommended for personal use): OAuth token from your Claude subscription.
# Generate via `claude setup-token` on the host. The token starts with `sk-ant-oat-...`.
# Note: Anthropic publicly documents this mechanism for Claude Code itself, but using it
# from third-party orchestrators like Sandcastle is in a grey area Anthropic hasn't
# publicly endorsed. See https://github.com/mattpocock/sandcastle/issues/191.
CLAUDE_CODE_OAUTH_TOKEN=

# Option B: pay-as-you-go Anthropic API key.
# ANTHROPIC_API_KEY=

# GitHub personal access token used by `gh` inside the sandbox.
# Needs: repo scope, plus issues:write and pull_requests:write.
GH_TOKEN=
